rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // -------------------------------------------------------------------------
    // Products Storage (ZIP Files, Images)
    // -------------------------------------------------------------------------
    // Allow anyone to read/download the assets.
    // 
    // IMPORTANT SECUIRTY NOTE: 
    // We are allowing public uploads for development purposes right now.
    // Once Authentication is ready, change `allow write: if true;` 
    // to `allow write: if request.auth != null;`
    // -------------------------------------------------------------------------
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
