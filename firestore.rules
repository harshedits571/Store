rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // Products Collection
    // -------------------------------------------------------------------------
    // Allow anyone to read the products (so the storefront works).
    // 
    // IMPORTANT SECUIRTY NOTE: 
    // We are currently allowing public 'write' access for development purposes
    // so you can add products via the Admin panel without logging in.
    // 
    // Once Firebase Authentication is set up for the Admin panel, 
    // change `allow write: if true;` to `allow write: if request.auth != null;`
    // -------------------------------------------------------------------------
    match /products/{productId} {
      allow read: if true;
      allow write: if true; 
    }
    
    // -------------------------------------------------------------------------
    // Leads / Orders Collection
    // -------------------------------------------------------------------------
    match /leads/{leadId} {
      allow read, write: if true; 
    }

    // -------------------------------------------------------------------------
    // Licenses Collection
    // -------------------------------------------------------------------------
    match /licenses/{licenseId} {
      allow read, write: if true; 
    }

    // -------------------------------------------------------------------------
    // License By Email Collection
    // -------------------------------------------------------------------------
    match /license_by_email/{email} {
      allow read, write: if true; 
    }

    // -------------------------------------------------------------------------
    // Customers Collection (CRM)
    // -------------------------------------------------------------------------
    match /customers/{customerId} {
      allow read, write: if true; 
    }

    // -------------------------------------------------------------------------
    // Custom Links Collection
    // -------------------------------------------------------------------------
    match /custom_links/{linkId} {
      allow read, write: if true; 
    }

    // -------------------------------------------------------------------------
    // Promocodes Collection
    // -------------------------------------------------------------------------
    match /promocodes/{promocodeId} {
      allow read, write: if true; 
    }

    // -------------------------------------------------------------------------
    // Settings Collection
    // -------------------------------------------------------------------------
    match /settings/{settingsId} {
      allow read, write: if true; 
    }
  }
}
